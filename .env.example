# OneSocial — Environment Variables
# Copy this to .env and fill in your AWS credentials.

# ── Server ────────────────────────────────────────
PORT=5000
VITE_API_URL=http://localhost:5000

# ── AI Provider ───────────────────────────────────
# Options: "bedrock" | "mock"
# Use "mock" to run without AWS credentials (UI testing only)
AI_PROVIDER=bedrock

# ── AWS Bedrock ───────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ── Bedrock Model IDs (defaults shown) ───────────
# Stage 1 — Content analysis + vision
BEDROCK_ANALYSIS_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Stage 3a — Caption generation (fast + high quality)
BEDROCK_CAPTION_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0

# Stage 3b — Image generation (AWS native)
BEDROCK_IMAGE_MODEL=amazon.nova-canvas-v1:0

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_MAX=10
