{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "jsx": "react-jsx",
        "strict": false,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": [
        "src",
        "server.js",
        "routes",
        "services",
        "providers",
        "utils"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}